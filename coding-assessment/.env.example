# Supabase (create project at supabase.com, free tier)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Judge0 (RapidAPI or official/self-hosted).
# Auth: rapidapi = X-RapidAPI-Key + X-RapidAPI-Host; token = X-Auth-Token (official API).
NEXT_PUBLIC_JUDGE0_BASE_URL=https://judge0-ce.p.rapidapi.com
NEXT_PUBLIC_JUDGE0_API_KEY=your-rapidapi-key
NEXT_PUBLIC_JUDGE0_AUTH=rapidapi
# Optional for RapidAPI: host header (default from BASE_URL).
# NEXT_PUBLIC_JUDGE0_HOST=judge0-ce.p.rapidapi.com

# Current exam (UUID from exams table)
NEXT_PUBLIC_EXAM_ID=your-exam-uuid

# Optional: exam window (ISO strings). If unset, exam runs 1 hour from page load.
# NEXT_PUBLIC_EXAM_START=2025-01-15T10:00:00Z
# NEXT_PUBLIC_EXAM_END=2025-01-15T11:00:00Z
