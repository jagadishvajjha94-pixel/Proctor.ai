# Database (required for production - 3000+ students)
DATABASE_URL="postgresql://user:password@localhost:5432/ai_interview?schema=public"

# OpenAI API (required for AI interview, code evaluation, eligibility decisions)
OPENAI_API_KEY="sk-your-openai-api-key"

# Session secret (required for production - min 32 chars)
# Generate: openssl rand -base64 32
SESSION_SECRET="your-secret-key-min-32-chars-for-production"

# Admin credentials (change in production!)
# Login: admin@proctorai.com / your-secure-password
ADMIN_PASSWORD="admin123"

# Google Sheets (optional - for export)
# GOOGLE_SHEETS_ID=""
# GOOGLE_SERVICE_ACCOUNT_KEY=""

# Node environment
NODE_ENV="development"
